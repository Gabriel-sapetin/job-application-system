# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
# Optional: service role for storage uploads (see app/routes/upload.py)
SUPABASE_SERVICE_KEY=

# ── Auth / app ─────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENV=development

# Comma-separated browser origins allowed for CORS + origin check
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── Rate limiting (app/rate_limit/factory.py) ───────────
# backend: memory (default) | disabled | trust_gateway | redis
RATE_LIMIT_BACKEND=memory
# Max requests per client key per window (memory/gateway placeholder; same env for future Redis)
RATE_LIMIT_GLOBAL_LIMIT=100
# Window in seconds
RATE_LIMIT_GLOBAL_WINDOW=60
# Required when RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
# Optional: if true and REDIS_URL is missing, fallback to memory instead of raising config error.
RATE_LIMIT_REDIS_FALLBACK_TO_MEMORY=false
# When behind nginx/traefik: use first X-Forwarded-For or X-Real-IP as client key
# Also used by security middleware to trust X-Forwarded-Proto: https (HSTS / HTTPS detection)
TRUST_PROXY=false

# ── Security headers (app/middleware/security.py) ─────
SECURITY_HEADERS_ENABLED=true
# HSTS is only sent when the request is considered HTTPS (see TRUST_PROXY + X-Forwarded-Proto)
HSTS_ENABLE=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
# Baseline CSP; override fully with one line (optional)
CONTENT_SECURITY_POLICY=
# Send CSP as report-only for debugging (set to 1/true/yes)
CSP_REPORT_ONLY=false
# CSP header (skipped on /docs, /redoc, /openapi.json). Set false to disable CSP entirely.
CSP_ENABLE=true
REFERRER_POLICY=strict-origin-when-cross-origin
# Clickjacking; leave empty to omit X-Frame-Options
X_FRAME_OPTIONS=DENY
# Optional: e.g. camera=(), microphone=(), geolocation=()
PERMISSIONS_POLICY=

# ── Email (password reset / notifications mail) ───────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Links in emails — match your frontend origin
FRONTEND_URL=http://127.0.0.1:5500/job-application-system/frontend
